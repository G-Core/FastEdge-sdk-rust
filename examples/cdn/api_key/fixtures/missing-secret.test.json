{
  "appType": "proxy-wasm",
  "description": "API_KEY secret not configured — returns 500 misconfigured",
  "request": {
    "method": "GET",
    "url": "http://fastedge-builtin.debug",
    "headers": {
      "host": "api.example.com",
      "X-API-Key": "test-api-key-12345"
    },
    "body": ""
  },
  "logLevel": 2,
  "wasm": {
    "path": "<workspace>/.fastedge-debug/app.wasm",
    "description": "Default debugger WASM binary"
  }
}
