{
  "appType": "proxy-wasm",
  "description": "No X-API-Key header — returns 401 with WWW-Authenticate challenge",
  "request": {
    "method": "GET",
    "url": "http://fastedge-builtin.debug",
    "headers": {
      "host": "api.example.com"
    },
    "body": ""
  },
  "dotenv": {
    "enabled": true,
    "path": "."
  },
  "logLevel": 2,
  "wasm": {
    "path": "<workspace>/.fastedge-debug/app.wasm",
    "description": "Default debugger WASM binary"
  }
}
