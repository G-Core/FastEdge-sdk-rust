{
  "appType": "proxy-wasm",
  "description": "Returning visitor with variant B cookie — routes to variant B path",
  "request": {
    "method": "GET",
    "url": "http://fastedge-builtin.debug",
    "headers": {
      "host": "example.com",
      "Cookie": "fe_exp_homepage-hero=B"
    },
    "body": ""
  },
  "properties": {
    "request.host": "example.com",
    "request.path": "/landing",
    "request.url": "http://example.com/landing"
  },
  "response": {
    "headers": {
      "content-type": "text/html"
    },
    "body": "<html><body>Variant B page</body></html>"
  },
  "dotenv": {
    "enabled": true,
    "path": "."
  },
  "logLevel": 2
}
