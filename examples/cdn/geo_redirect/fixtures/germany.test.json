{
  "appType": "proxy-wasm",
  "description": "Country code DE - redirects to Germany-specific origin",
  "request": {
    "method": "GET",
    "url": "http://fastedge-builtin.debug",
    "headers": {
      "host": "example.com"
    },
    "body": ""
